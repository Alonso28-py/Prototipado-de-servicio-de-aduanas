<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SGAI - Paso Pehuenche | V1.0</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center p-4">

    <div class="bg-white rounded-xl shadow-lg p-8 max-w-md w-full border-t-4 border-blue-800">
        
        <div class="text-center mb-6">
            <h1 class="text-2xl font-bold text-blue-900">SGAI Aduanas</h1>
            <p class="text-sm text-slate-500">Paso Fronterizo Pehuenche - Prototipo V1.0</p>
        </div>

        <form id="formularioAduana" class="space-y-4" onsubmit="event.preventDefault(); simularEnvio();">
            
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">RUT o Pasaporte</label>
                <input type="text" id="rut" placeholder="Ej: 12.345.678-9" 
                       class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Patente del Vehículo</label>
                <input type="text" id="patente" placeholder="Ej: ABCD12 o C.D." 
                       class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                <p class="text-xs text-slate-500 mt-1">* Para diplomáticos ingrese "C.D." o "CC".</p>
            </div>

            <button type="submit" 
                    class="w-full bg-blue-800 hover:bg-blue-900 text-white font-bold py-3 px-4 rounded-lg transition duration-200 mt-4 shadow-md">
                Generar Trámite
            </button>
        </form>

        <div id="resultado" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-lg text-center">
            <p class="text-green-800 font-semibold">¡Trámite guardado en versión 1.0!</p>
            <p class="text-sm text-green-600 mt-1">(Aún sin validación de días ni QR)</p>
        </div>

    </div>

    <script>
        function simularEnvio() {
            // En esta Iteración 1, solo mostramos el mensaje de éxito sin validar nada.
            document.getElementById('resultado').classList.remove('hidden');
        }
    </script>
</body>
</html>
